# Do not paste real credentials into chat.
# Copy this file to .env and fill only the values you want to use locally.

# Optional: full Mein.Libri credentials for a future browser-login collector.
# The current pipeline does not need these for public image URL validation.
LIBRI_CUSTOMER_NUMBER=
LIBRI_USERNAME=
LIBRI_PASSWORD=

# Optional: session cookie copied from a logged-in Mein.Libri browser session.
# Used only to diagnose whether a Libri image works with login but not publicly.
# TikTok cannot use this cookie, so authenticated-only images stay out of green uploads.
LIBRI_COOKIE=

# TikTok Shop Open API.
# Create/authorize an app in TikTok Shop Partner Center, then fill these locally.
# Required scopes usually include order read access and seller authorization info.
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=
TIKTOK_ACCESS_TOKEN_EXPIRES_IN=
TIKTOK_ACCESS_TOKEN_EXPIRES_AT=

# Optional if the access token authorizes exactly one shop. If multiple shops are
# authorized, run once without this value and the script will tell you to set it.
TIKTOK_SHOP_CIPHER=

# Optional TikTok warehouse used for inventory updates. The current scripts have
# a project default, but setting this explicitly is safer if the shop changes.
TIKTOK_WAREHOUSE_ID=

TIKTOK_BASE_URL=https://open-api.tiktokglobalshop.com
TIKTOK_API_VERSION=202309
TIKTOK_ORDER_STATUS=AWAITING_SHIPMENT
TIKTOK_INCLUDE_VERSION=true
TIKTOK_ACCESS_TOKEN_IN_QUERY=false
TIKTOK_SIGN_INCLUDE_BODY=true

# Optional fulfillment handback configuration for TikTok Shop tracking updates.
TIKTOK_SHIPPING_PROVIDER_NAME=DHL
TIKTOK_SHIPPING_PROVIDER_ID=
TIKTOK_SHIP_PACKAGE_PATH_TEMPLATE=/fulfillment/{version}/packages/{package_id}/ship

# Optional integration-audit probes.
LIBRI_DELIVERY_NOTE_URLS=
TIKTOK_AFFILIATE_AUDIT_PATHS=

# Optional: Cloudinary hosting for repaired TikTok image URLs.
# Create a free Cloudinary account, then copy these values from the dashboard.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=tiktokshop/books
