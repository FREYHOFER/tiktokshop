;(function ( $, window, document, undefined ) {

    "use strict";

    $('.snippetPasswordStrength').each(function(){
        var self = $(this);
        $("#" + $(this).data('target')).complexify({strengthScaleFactor: 0.5}, function(valid, complexity){
            var steps = self.find('.step');
            steps.removeClass('on');
            var percentToSubtract = 100 / steps.length;
            var i;
            for (i = 0; i < steps.length; i++) {
                if(complexity > 0) {
                    steps.eq(i).addClass('on');
                }
                complexity = complexity - percentToSubtract;
            }
            self.show();
            self.find('.strength-text').html(self.find('.on').last().data('label'));
        });

    });

})( jQuery, window, document );
